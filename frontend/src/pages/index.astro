---
import '@/styles/globals.css';
import Chat from '@/components/Chat';
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Python RAG Assistant</title>
  </head>
  <body class="bg-[#050505] text-foreground antialiased min-h-screen overflow-hidden selection:bg-primary/30">
    <div class="fixed inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(17,24,39,1),rgba(0,0,0,1))] -z-10"></div>
    <div class="fixed inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 brightness-100 contrast-150 pointer-events-none -z-10"></div>
    <Chat client:load />
  </body>
</html>
